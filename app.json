{
  "expo": {
    "name": "Koinonia",
    "slug": "koinonia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/koinonia_icon_1024.png",
    "scheme": "koinonia",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koinonia.app"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#000000",
      "translucent": false
    },
    "android": {
      "package": "com.koinonia.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/koinonia_icon_1024.png",
        "monochromeImage": "./assets/images/koinonia_icon_1024.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/koinonia_icon_1024.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/koinonia_icon_1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ea09c22-e203-49ee-acf3-36c4a22b1735"
      }
    }
  }
}
